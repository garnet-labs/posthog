{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "description": "Serializer mixin that handles tags for objects.",
    "properties": {
        "breakdown_colors": {},
        "data_color_theme_id": {
            "anyOf": [
                {
                    "type": "number"
                },
                {
                    "type": "null"
                }
            ]
        },
        "delete_insights": {
            "default": false,
            "type": "boolean"
        },
        "description": {
            "type": "string"
        },
        "name": {
            "anyOf": [
                {
                    "maxLength": 400,
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        },
        "pinned": {
            "type": "boolean"
        },
        "restriction_level": {
            "anyOf": [
                {
                    "const": 21,
                    "type": "number"
                },
                {
                    "const": 37,
                    "type": "number"
                }
            ],
            "description": "* `21` - Everyone in the project can edit\n* `37` - Only those invited to this dashboard can edit"
        },
        "tags": {
            "items": {},
            "type": "array"
        },
        "use_dashboard": {
            "anyOf": [
                {
                    "type": "number"
                },
                {
                    "type": "null"
                }
            ]
        },
        "use_template": {
            "type": "string"
        }
    },
    "type": "object"
}
