{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "calculation_interval": {
            "anyOf": [
                {
                    "anyOf": [
                        {
                            "description": "* `hourly` - hourly\n* `daily` - daily\n* `weekly` - weekly\n* `monthly` - monthly",
                            "enum": ["hourly", "daily", "weekly", "monthly"],
                            "type": "string"
                        },
                        {
                            "enum": [""],
                            "type": "string"
                        },
                        {
                            "const": null,
                            "type": "null"
                        }
                    ]
                },
                {
                    "type": "null"
                }
            ]
        },
        "condition": {
            "anyOf": [
                {
                    "properties": {
                        "type": {
                            "enum": ["absolute_value", "relative_increase", "relative_decrease"],
                            "type": "string"
                        }
                    },
                    "required": ["type"],
                    "type": "object"
                },
                {
                    "type": "null"
                }
            ]
        },
        "config": {
            "anyOf": [
                {
                    "properties": {
                        "check_ongoing_interval": {
                            "anyOf": [
                                {
                                    "type": "boolean"
                                },
                                {
                                    "type": "null"
                                }
                            ]
                        },
                        "series_index": {
                            "type": "number"
                        },
                        "type": {
                            "default": "TrendsAlertConfig",
                            "enum": ["TrendsAlertConfig"],
                            "type": "string"
                        }
                    },
                    "required": ["series_index"],
                    "type": "object"
                },
                {
                    "type": "null"
                }
            ]
        },
        "enabled": {
            "type": "boolean"
        },
        "id": {
            "description": "A UUID string identifying this alert configuration.",
            "type": "string"
        },
        "insight": {
            "description": "Insight ID monitored by this alert. Note: Response returns full InsightBasicSerializer object.",
            "type": "number"
        },
        "name": {
            "maxLength": 255,
            "type": "string"
        },
        "skip_weekend": {
            "anyOf": [
                {
                    "type": "boolean"
                },
                {
                    "type": "null"
                }
            ]
        },
        "snoozed_until": {
            "anyOf": [
                {
                    "format": "date-time",
                    "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        },
        "subscribed_users": {
            "description": "User IDs to subscribe to this alert. Note: Response returns full UserBasicSerializer object.",
            "items": {
                "type": "number"
            },
            "type": "array"
        },
        "threshold": {
            "properties": {
                "configuration": {
                    "properties": {
                        "bounds": {
                            "anyOf": [
                                {
                                    "properties": {
                                        "lower": {
                                            "anyOf": [
                                                {
                                                    "type": "number"
                                                },
                                                {
                                                    "type": "null"
                                                }
                                            ]
                                        },
                                        "upper": {
                                            "anyOf": [
                                                {
                                                    "type": "number"
                                                },
                                                {
                                                    "type": "null"
                                                }
                                            ]
                                        }
                                    },
                                    "type": "object"
                                },
                                {
                                    "type": "null"
                                }
                            ]
                        },
                        "type": {
                            "enum": ["absolute", "percentage"],
                            "type": "string"
                        }
                    },
                    "required": ["type"],
                    "type": "object"
                },
                "created_at": {
                    "format": "date-time",
                    "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                    "type": "string"
                },
                "id": {
                    "type": "string"
                },
                "name": {
                    "maxLength": 255,
                    "type": "string"
                }
            },
            "required": ["configuration"],
            "type": "object"
        }
    },
    "required": ["id"],
    "type": "object"
}
