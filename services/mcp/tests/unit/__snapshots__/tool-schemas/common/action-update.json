{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "description": {
            "type": "string"
        },
        "id": {
            "description": "A unique integer value identifying this action.",
            "type": "number"
        },
        "name": {
            "anyOf": [
                {
                    "maxLength": 400,
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        },
        "pinned_at": {
            "anyOf": [
                {
                    "format": "date-time",
                    "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))T(?:(?:[01]\\d|2[0-3]):[0-5]\\d(?::[0-5]\\d(?:\\.\\d+)?)?(?:Z))$",
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        },
        "post_to_slack": {
            "type": "boolean"
        },
        "slack_message_format": {
            "maxLength": 1200,
            "type": "string"
        },
        "steps": {
            "items": {
                "properties": {
                    "event": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "href": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "href_matching": {
                        "anyOf": [
                            {
                                "anyOf": [
                                    {
                                        "description": "* `contains` - contains\n* `regex` - regex\n* `exact` - exact",
                                        "enum": ["contains", "regex", "exact"],
                                        "type": "string"
                                    },
                                    {
                                        "const": null,
                                        "type": "null"
                                    }
                                ]
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "properties": {
                        "anyOf": [
                            {
                                "items": {
                                    "additionalProperties": {},
                                    "propertyNames": {
                                        "type": "string"
                                    },
                                    "type": "object"
                                },
                                "type": "array"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "selector": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "selector_regex": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "tag_name": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "text": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "text_matching": {
                        "anyOf": [
                            {
                                "anyOf": [
                                    {
                                        "description": "* `contains` - contains\n* `regex` - regex\n* `exact` - exact",
                                        "enum": ["contains", "regex", "exact"],
                                        "type": "string"
                                    },
                                    {
                                        "const": null,
                                        "type": "null"
                                    }
                                ]
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "url": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ]
                    },
                    "url_matching": {
                        "anyOf": [
                            {
                                "anyOf": [
                                    {
                                        "description": "* `contains` - contains\n* `regex` - regex\n* `exact` - exact",
                                        "enum": ["contains", "regex", "exact"],
                                        "type": "string"
                                    },
                                    {
                                        "const": null,
                                        "type": "null"
                                    }
                                ]
                            },
                            {
                                "type": "null"
                            }
                        ]
                    }
                },
                "type": "object"
            },
            "type": "array"
        },
        "tags": {
            "items": {},
            "type": "array"
        }
    },
    "required": ["id"],
    "type": "object"
}
