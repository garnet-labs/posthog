{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "description": {
            "type": "string"
        },
        "documentation_url": {
            "format": "uri",
            "maxLength": 800,
            "type": "string"
        },
        "id": {
            "description": "A UUID string identifying this early access feature.",
            "type": "string"
        },
        "name": {
            "maxLength": 200,
            "type": "string"
        },
        "stage": {
            "description": "* `draft` - draft\n* `concept` - concept\n* `alpha` - alpha\n* `beta` - beta\n* `general-availability` - general availability\n* `archived` - archived",
            "enum": ["draft", "concept", "alpha", "beta", "general-availability", "archived"],
            "type": "string"
        }
    },
    "required": ["id"],
    "type": "object"
}
