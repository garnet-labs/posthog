{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "query": {
            "description": "Sparkline query parameters.",
            "properties": {
                "dateRange": {
                    "description": "Date range for the sparkline query.",
                    "properties": {
                        "date_from": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "null"
                                }
                            ]
                        },
                        "date_to": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "null"
                                }
                            ]
                        },
                        "explicitDate": {
                            "default": false,
                            "description": "Whether the date_from and date_to should be used verbatim. Disables rounding to the start and end of period.",
                            "type": "boolean"
                        }
                    },
                    "type": "object"
                },
                "filterGroup": {
                    "anyOf": [
                        {},
                        {
                            "type": "null"
                        }
                    ],
                    "description": "Property filter group object for structured filtering."
                },
                "searchTerm": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "description": "Free text search term to filter log entries."
                },
                "serviceNames": {
                    "description": "Filter by service names.",
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "severityLevels": {
                    "description": "Filter by severity levels (trace, debug, info, warn, error, fatal).",
                    "items": {
                        "description": "* `trace` - trace\n* `debug` - debug\n* `info` - info\n* `warn` - warn\n* `error` - error\n* `fatal` - fatal",
                        "enum": ["trace", "debug", "info", "warn", "error", "fatal"],
                        "type": "string"
                    },
                    "type": "array"
                },
                "sparklineBreakdownBy": {
                    "anyOf": [
                        {
                            "anyOf": [
                                {
                                    "description": "* `severity` - severity\n* `service` - service",
                                    "enum": ["severity", "service"],
                                    "type": "string"
                                },
                                {
                                    "const": null,
                                    "type": "null"
                                }
                            ]
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "description": "Break down sparkline data by severity level or service name (default: severity).\n\n* `severity` - severity\n* `service` - service"
                }
            },
            "required": ["dateRange"],
            "type": "object"
        }
    },
    "required": ["query"],
    "type": "object"
}
