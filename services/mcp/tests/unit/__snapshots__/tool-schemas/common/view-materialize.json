{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "properties": {
        "deleted": {
            "anyOf": [
                {
                    "type": "boolean"
                },
                {
                    "type": "null"
                }
            ]
        },
        "edited_history_id": {
            "anyOf": [
                {
                    "type": "string"
                },
                {
                    "type": "null"
                }
            ]
        },
        "id": {
            "description": "A UUID string identifying this data warehouse saved query.",
            "type": "string"
        },
        "name": {
            "maxLength": 128,
            "type": "string"
        },
        "query": {
            "anyOf": [
                {},
                {
                    "type": "null"
                }
            ],
            "description": "HogQL query"
        },
        "soft_update": {
            "anyOf": [
                {
                    "type": "boolean"
                },
                {
                    "type": "null"
                }
            ]
        }
    },
    "required": ["id", "name"],
    "type": "object"
}
