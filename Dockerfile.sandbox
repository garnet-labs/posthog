# Dev sandbox image for isolated branch environments.
#
# Python base and uv version match the production Dockerfile so pins stay in sync.
# PostHog source is NOT baked in — it's mounted from a host worktree at runtime.

# Same base as the posthog-build stage in Dockerfile
FROM python:3.12.12-slim-bookworm

# Same uv version as Dockerfile
COPY --from=ghcr.io/astral-sh/uv:0.10.2 /uv /uvx /usr/local/bin/

SHELL ["/bin/bash", "-e", "-o", "pipefail", "-c"]

# System deps for building Python/Rust packages + dev tools
RUN apt-get update && apt-get install -y --no-install-recommends \
    brotli \
    build-essential \
    cmake \
    curl \
    git \
    jq \
    libclang-dev \
    libffi-dev \
    libpq-dev \
    libssl-dev \
    libxml2-dev \
    libxmlsec1-dev \
    libxslt1-dev \
    pkg-config \
    postgresql-client \
    protobuf-compiler \
    tmux \
    unzip \
    vim \
    zlib1g-dev \
    && rm -rf /var/lib/apt/lists/*

# Same Node.js version as Dockerfile
ENV NODE_VERSION=24.13.0
RUN ARCH=$(dpkg --print-architecture) && \
    case "${ARCH}" in \
        amd64) NODE_ARCH='x64';; \
        arm64) NODE_ARCH='arm64';; \
        *) echo "unsupported: ${ARCH}"; exit 1;; \
    esac && \
    curl -fsSL "https://nodejs.org/dist/v${NODE_VERSION}/node-v${NODE_VERSION}-linux-${NODE_ARCH}.tar.xz" \
    | tar xJ -C /usr/local --strip-components=1 --no-same-owner

# pnpm (corepack reads the pinned version from package.json at install time)
RUN corepack enable

# mprocs (process manager used by bin/start)
RUN ARCH=$(dpkg --print-architecture) && \
    case "${ARCH}" in \
        amd64) MPROCS_ARCH='x86_64';; \
        arm64) MPROCS_ARCH='aarch64';; \
        *) echo "unsupported: ${ARCH}"; exit 1;; \
    esac && \
    curl -fsSL "https://github.com/pvolok/mprocs/releases/download/v0.9.2/mprocs-0.9.2-linux-${MPROCS_ARCH}-musl.tar.gz" \
    | tar xz -C /usr/local/bin/

# Claude Code CLI
RUN npm install -g @anthropic-ai/claude-code

# Rust toolchain (cyclotron-node native addon + Rust services)
# Installed to /usr/local so non-root container users can access cargo
ENV RUSTUP_HOME=/usr/local/rustup \
    CARGO_HOME=/usr/local/cargo \
    PATH="/usr/local/cargo/bin:$PATH"
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --no-modify-path \
    && chmod -R a+rwx /usr/local/cargo /usr/local/rustup

# rpk (Redpanda CLI) — used to pre-create Kafka topics before services start.
# Version pinned to match the Redpanda image in docker-compose.base.yml.
RUN ARCH=$(dpkg --print-architecture) && \
    curl -fsSL "https://github.com/redpanda-data/redpanda/releases/download/v25.1.9/rpk-linux-${ARCH}.zip" \
    -o /tmp/rpk.zip && unzip -o /tmp/rpk.zip -d /usr/local/bin/ rpk && rm /tmp/rpk.zip

# Shared cache directories — mounted as named volumes in docker-compose.sandbox.yml.
# Created with open permissions so any UID can write (container runs as host user).
RUN mkdir -p /cache/uv /cache/pnpm && chmod 777 /cache/uv /cache/pnpm

ENV NODE_ENV=development
WORKDIR /workspace

COPY --chmod=755 bin/sandbox-entrypoint.sh /usr/local/bin/sandbox-entrypoint.sh

# --- PRE-MERGE WORKAROUND (delete this block after merging to master) ---
# See sandbox-entrypoint.sh for details.
COPY bin/wait-for-docker     /usr/local/share/sandbox/bin/wait-for-docker
COPY bin/mprocs.yaml         /usr/local/share/sandbox/bin/mprocs.yaml
COPY bin/start-backend       /usr/local/share/sandbox/bin/start-backend
COPY bin/start-rust-service  /usr/local/share/sandbox/bin/start-rust-service
COPY posthog/management/commands/sandbox_migrate.py /usr/local/share/sandbox/posthog/management/commands/sandbox_migrate.py
COPY nodejs/package.json     /usr/local/share/sandbox/nodejs/package.json
COPY rust/cyclotron-node/package.json /usr/local/share/sandbox/rust/cyclotron-node/package.json
# --- END PRE-MERGE WORKAROUND ---

ENTRYPOINT ["/usr/local/bin/sandbox-entrypoint.sh"]
