{
    "compilerOptions": {
        "target": "ES2022",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "strict": true,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "resolveJsonModule": true,
        "allowSyntheticDefaultImports": true,
        "noEmit": true,
        "types": ["node", "vitest/globals"],
        "typeRoots": ["../../../node_modules/.pnpm/node_modules/@types", "../../../node_modules/.pnpm/node_modules"],
        "rootDir": "."
    },
    "include": ["src/**/*.ts", "src/**/*.d.ts"]
}
